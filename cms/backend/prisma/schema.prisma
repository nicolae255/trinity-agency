generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ActivityAction {
  LOGIN
  LOGOUT
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  UPLOAD
  PASSWORD_RESET
}

enum ActivityEntity {
  USER
  PAGE
  POST
  MEDIA
  CATEGORY
  TAG
  SETTINGS
}

// ─── USER ──────────────────────────────────────────────

model User {
  id                   String    @id @default(uuid()) @db.Uuid
  email                String    @unique
  password             String
  firstName            String    @map("first_name")
  lastName             String    @map("last_name")
  role                 Role      @default(AUTHOR)
  avatar               String?
  isActive             Boolean   @default(true) @map("is_active")
  refreshTokenHash     String?   @map("refresh_token_hash")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  lastLoginAt          DateTime? @map("last_login_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  // Multi-tenancy ready
  // tenantId String? @map("tenant_id") @db.Uuid

  posts        Post[]
  pages        Page[]
  activityLogs ActivityLog[]
  media        Media[]

  @@map("users")
}

// ─── PAGES ─────────────────────────────────────────────

model Page {
  id              String        @id @default(uuid()) @db.Uuid
  title           String
  slug            String        @unique
  content         Json?
  contentHtml     String?       @map("content_html") @db.Text
  status          ContentStatus @default(DRAFT)
  featuredImageId String?       @map("featured_image_id") @db.Uuid
  sortOrder       Int           @default(0) @map("sort_order")
  parentId        String?       @map("parent_id") @db.Uuid

  // SEO
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  ogTitle         String? @map("og_title")
  ogDescription   String? @map("og_description") @db.Text
  canonicalUrl    String? @map("canonical_url")
  ogImageId       String? @map("og_image_id") @db.Uuid

  authorId    String    @map("author_id") @db.Uuid
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Multi-tenancy ready
  // tenantId String? @map("tenant_id") @db.Uuid

  author        User   @relation(fields: [authorId], references: [id])
  featuredImage Media? @relation("PageFeaturedImage", fields: [featuredImageId], references: [id])
  ogImage       Media? @relation("PageOgImage", fields: [ogImageId], references: [id])
  parent        Page?  @relation("PageHierarchy", fields: [parentId], references: [id])
  children      Page[] @relation("PageHierarchy")

  @@index([status])
  @@index([slug])
  @@index([authorId])
  @@map("pages")
}

// ─── BLOG ──────────────────────────────────────────────

model Post {
  id              String        @id @default(uuid()) @db.Uuid
  title           String
  slug            String        @unique
  excerpt         String?       @db.Text
  content         Json?
  contentHtml     String?       @map("content_html") @db.Text
  status          ContentStatus @default(DRAFT)
  featuredImageId String?       @map("featured_image_id") @db.Uuid

  // SEO
  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description") @db.Text
  ogTitle         String? @map("og_title")
  ogDescription   String? @map("og_description") @db.Text
  canonicalUrl    String? @map("canonical_url")
  ogImageId       String? @map("og_image_id") @db.Uuid

  authorId    String    @map("author_id") @db.Uuid
  publishedAt DateTime? @map("published_at")
  scheduledAt DateTime? @map("scheduled_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Multi-tenancy ready
  // tenantId String? @map("tenant_id") @db.Uuid

  author        User           @relation(fields: [authorId], references: [id])
  featuredImage Media?         @relation("PostFeaturedImage", fields: [featuredImageId], references: [id])
  ogImage       Media?         @relation("PostOgImage", fields: [ogImageId], references: [id])
  categories    PostCategory[]
  tags          PostTag[]

  @@index([status])
  @@index([slug])
  @@index([authorId])
  @@index([publishedAt])
  @@index([scheduledAt])
  @@map("posts")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique
  slug        String   @unique
  description String?  @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent   Category?      @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[]     @relation("CategoryHierarchy")
  posts    PostCategory[]

  @@map("categories")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  posts PostTag[]

  @@map("tags")
}

model PostCategory {
  postId     String   @map("post_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  post     Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([postId, categoryId])
  @@map("post_categories")
}

model PostTag {
  postId     String   @map("post_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

// ─── MEDIA ─────────────────────────────────────────────

model Media {
  id           String   @id @default(uuid()) @db.Uuid
  filename     String
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  size         Int
  width        Int?
  height       Int?
  url          String
  altText      String?  @map("alt_text")
  caption      String?  @db.Text
  folder       String   @default("/")
  uploadedById String   @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Multi-tenancy ready
  // tenantId String? @map("tenant_id") @db.Uuid

  uploadedBy         User   @relation(fields: [uploadedById], references: [id])
  pageFeaturedImages Page[] @relation("PageFeaturedImage")
  pageOgImages       Page[] @relation("PageOgImage")
  postFeaturedImages Post[] @relation("PostFeaturedImage")
  postOgImages       Post[] @relation("PostOgImage")

  @@index([folder])
  @@index([mimeType])
  @@map("media")
}

// ─── ACTIVITY LOGS ─────────────────────────────────────

model ActivityLog {
  id          String         @id @default(uuid()) @db.Uuid
  action      ActivityAction
  entity      ActivityEntity
  entityId    String?        @map("entity_id") @db.Uuid
  entityTitle String?        @map("entity_title")
  details     Json?
  ipAddress   String?        @map("ip_address")
  userAgent   String?        @map("user_agent") @db.Text
  userId      String         @map("user_id") @db.Uuid
  createdAt   DateTime       @default(now()) @map("created_at")

  // Multi-tenancy ready
  // tenantId String? @map("tenant_id") @db.Uuid

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── ANALYTICS ─────────────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(uuid()) @db.Uuid
  event     String
  path      String
  referrer  String?
  sessionId String   @map("session_id")
  visitorId String   @map("visitor_id")
  country   String?
  device    String?
  browser   String?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([event])
  @@index([path])
  @@index([createdAt])
  @@map("analytics_events")
}
